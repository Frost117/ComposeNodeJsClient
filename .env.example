# TV Maze API (Data Source)
FETCH_ENDPOINT_URL=https://api.tvmaze.com/shows

# Umbraco Compose (Import Destination)
COMPOSE_INGESTION_URL=https://ingest.germanywestcentral.umbracocompose.com # The base URL and region for the Umbraco Compose ingestion API
COMPOSE_MANAGEMENT_URL=https://management.germanywestcentral.umbracocompose.com # The base URL and region for the Umbraco Compose management API
COMPOSE_PROJECT_ALIAS=your_project_alias
COMPOSE_ENVIRONMENT_ALIAS=your_environment_alias #used for fallback when environment is not available.
COMPOSE_COLLECTION_ALIAS=your_collection_alias #used for fallback when collection is not available.

# Umbraco Compose OAuth2 Credentials
COMPOSE_CLIENT_ID=your_client_id
COMPOSE_CLIENT_SECRET=your_client_secret
COMPOSE_API_KEY_ALIAS=your_api_key_alias
COMPOSE_API_KEY=your_api_key_for_ingestion